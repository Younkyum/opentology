{
  "name": "opentology",
  "version": "0.1.0",
  "description": "CLI-managed RDF/SPARQL infrastructure — Supabase for RDF",
  "type": "module",
  "bin": {
    "opentology": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "rdf",
    "sparql",
    "ontology",
    "knowledge-graph",
    "linked-data",
    "shacl",
    "cli",
    "semantic-web"
  ],
  "author": "Younkyum Jin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Younkyum/opentology.git"
  },
  "homepage": "https://github.com/Younkyum/opentology#readme",
  "bugs": {
    "url": "https://github.com/Younkyum/opentology/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "n3": "^2.0.3",
    "oxigraph": "^0.5.6",
    "picocolors": "^1.1.1",
    "rdf-ext": "^2.6.0",
    "shacl-engine": "^1.1.0"
  },
  "devDependencies": {
    "@types/n3": "^1.26.1",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
