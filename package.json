{
  "name": "opentology",
  "version": "0.2.5",
  "description": "Ontology-powered project memory for AI coding assistants — your codebase as a knowledge graph",
  "type": "module",
  "bin": {
    "opentology": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "knowledge-graph",
    "ontology",
    "rdf",
    "sparql",
    "ai-coding",
    "project-memory",
    "codebase-context",
    "claude-code",
    "shacl"
  ],
  "author": "Younkyum Jin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Younkyum/opentology.git"
  },
  "homepage": "https://github.com/Younkyum/opentology#readme",
  "bugs": {
    "url": "https://github.com/Younkyum/opentology/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "n3": "^2.0.3",
    "oxigraph": "^0.5.6",
    "picocolors": "^1.1.1",
    "rdf-ext": "^2.6.0",
    "shacl-engine": "^1.1.0"
  },
  "peerDependencies": {
    "ts-morph": ">=21.0.0",
    "web-tree-sitter": ">=0.24.0",
    "tree-sitter-wasms": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "ts-morph": {
      "optional": true
    },
    "web-tree-sitter": {
      "optional": true
    },
    "tree-sitter-wasms": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/n3": "^1.26.1",
    "@types/node": "^25.5.0",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "web-tree-sitter": "^0.26.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
